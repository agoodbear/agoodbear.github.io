{
  "rules": {
    ".read": false,
    ".write": false,
    "pageViews": {
      ".read": false,
      ".write": false,
      "total": {
        ".read": true,
        ".write": "newData.isNumber() && ((!data.exists() && newData.val() >= 0) || (data.isNumber() && newData.val() == data.val() + 1))"
      }
    },
    "writeStudio": {
      ".read": false,
      ".write": false
    }
  }
}
