{{ define "main" }}
{{ $pages := .RegularPages.ByDate.Reverse }}
{{ $yearGroups := $pages.GroupByDate "2006" }}
<div class="wrap content ai-learning-page">
    <div class="ai-learning-layout">
        <article class="post_content ai-learning-content ai-learning-main">
            <h1 class="post_title">{{ .Title }}</h1>
            {{ with .Description }}
            <p class="ai-learning-description">{{ . }}</p>
            {{ end }}

            <div class="post_body ai-learning-intro">
                {{ .Content }}
            </div>

            <section class="ai-learning-entries" aria-label="AI 學習紀錄">
                {{ if $pages }}
                {{ range $yearGroup := $yearGroups }}
                {{ $yearKey := $yearGroup.Key }}
                <section class="ai-learning-year-block" aria-label="{{ $yearKey }} 年 AI 學習紀錄">
                    <div class="ai-learning-year-heading">{{ $yearKey }}年</div>
                    {{ range $monthGroup := $yearGroup.Pages.GroupByDate "01" }}
                    <section class="ai-learning-month-block" id="month-{{ $yearKey }}-{{ $monthGroup.Key }}">
                        <div class="ai-learning-month-heading">{{ (index $monthGroup.Pages 0).Date.Format "1月" }}</div>
                        <div class="ai-learning-month-entries">
                            {{ range $monthGroup.Pages.ByDate.Reverse }}
                            <article class="ai-learning-entry" id="entry-{{ .Date.Format "2006-01-02" }}">
                                <div class="ai-learning-entry-date">{{ .Date.Format "2006/1/2" }}</div>
                                <div class="ai-learning-entry-body">
                                    {{ .Content }}
                                </div>
                            </article>
                            {{ end }}
                        </div>
                    </section>
                    {{ end }}
                </section>
                {{ end }}
                {{ else }}
                <div class="ai-learning-empty">尚未新增 AI 學習紀錄，之後會依日期持續累積。</div>
                {{ end }}
            </section>
        </article>

        {{ if $pages }}
        <aside class="ai-learning-sidebar" aria-label="AI 學習月份導覽">
            <section class="ai-learning-search-panel" aria-label="AI 學習頁內搜尋">
                <div class="ai-learning-search-field">
                    <input
                        id="ai-learning-search-input"
                        class="ai-learning-search-input"
                        type="search"
                        placeholder="搜尋日期、關鍵字、心得..."
                        autocomplete="off"
                        spellcheck="false"
                    >
                    <button type="button" class="ai-learning-search-clear" id="ai-learning-search-clear" hidden>清除</button>
                </div>
                <div class="ai-learning-search-toolbar" id="ai-learning-search-toolbar" hidden>
                    <div class="ai-learning-search-count" id="ai-learning-search-count" aria-live="polite">0篇符合</div>
                    <div class="ai-learning-search-nav">
                        <button type="button" class="ai-learning-search-step" id="ai-learning-search-prev" aria-label="上一個搜尋結果">↑</button>
                        <div class="ai-learning-search-position" id="ai-learning-search-position" aria-live="polite">0 / 0</div>
                        <button type="button" class="ai-learning-search-step" id="ai-learning-search-next" aria-label="下一個搜尋結果">↓</button>
                    </div>
                </div>
            </section>
            <nav class="ai-learning-jump-nav">
                <div class="ai-learning-jump-title">快速跳轉</div>
                <div class="ai-learning-jump-groups">
                    {{ range $yearIndex, $yearGroup := $yearGroups }}
                    {{ $yearKey := $yearGroup.Key }}
                    <details class="ai-learning-year-menu" {{ if eq $yearIndex 0 }}open{{ end }}>
                        <summary>{{ $yearKey }}年</summary>
                        <div class="ai-learning-month-links">
                            {{ range $monthGroup := $yearGroup.Pages.GroupByDate "01" }}
                            <a href="#month-{{ $yearKey }}-{{ $monthGroup.Key }}" class="ai-learning-month-link" data-target-month="month-{{ $yearKey }}-{{ $monthGroup.Key }}">
                                {{ (index $monthGroup.Pages 0).Date.Format "1月" }}
                            </a>
                            {{ end }}
                        </div>
                    </details>
                    {{ end }}
                </div>
            </nav>
        </aside>
        {{ end }}
    </div>
</div>

<style>
    .ai-learning-page {
        max-width: 1360px;
    }

    .ai-learning-layout {
        display: block;
    }

    .ai-learning-content {
        width: 100%;
        max-width: none;
    }

    .ai-learning-description {
        margin-top: 0.75rem;
        color: var(--text);
        opacity: 0.82;
        line-height: 1.8;
    }

    .ai-learning-intro {
        margin-bottom: 2rem;
    }

    .ai-learning-search-panel,
    .ai-learning-jump-nav {
        padding: 1.15rem 1.2rem;
        border-radius: 18px;
        background: linear-gradient(135deg, rgba(7, 89, 133, 0.08), rgba(14, 165, 233, 0.12));
        border: 1px solid rgba(14, 116, 144, 0.12);
        box-shadow: 0 10px 24px rgba(15, 23, 42, 0.06);
    }

    .ai-learning-sidebar {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        margin-bottom: 2.25rem;
    }

    .ai-learning-jump-title {
        font-size: 0.95rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        color: #0c4a6e;
        text-transform: uppercase;
        margin-bottom: 0.85rem;
    }

    .ai-learning-search-field {
        display: flex;
        align-items: center;
        gap: 0.6rem;
    }

    .ai-learning-search-input {
        flex: 1;
        min-width: 0;
        height: 2.8rem;
        padding: 0.75rem 0.95rem;
        border-radius: 14px;
        border: 1px solid rgba(15, 126, 199, 0.22);
        background: rgba(255, 255, 255, 0.9);
        color: #12324a;
        font-size: 0.98rem;
        transition: border-color 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
    }

    .ai-learning-search-input::placeholder {
        color: rgba(18, 50, 74, 0.55);
    }

    .ai-learning-search-input:hover {
        border-color: rgba(15, 126, 199, 0.35);
    }

    .ai-learning-search-input:focus-visible {
        outline: none;
        border-color: #0f7ec7;
        background: #ffffff;
        box-shadow: 0 0 0 4px rgba(14, 165, 233, 0.18);
    }

    .ai-learning-search-clear {
        flex: 0 0 auto;
        height: 2.8rem;
        padding: 0 0.9rem;
        border: 1px solid rgba(15, 126, 199, 0.18);
        border-radius: 14px;
        background: rgba(255, 255, 255, 0.86);
        color: #0f4c75;
        font-weight: 700;
        cursor: pointer;
        transition: transform 0.15s ease, background 0.15s ease, color 0.15s ease;
    }

    .ai-learning-search-clear:hover,
    .ai-learning-search-clear:focus-visible {
        outline: none;
        background: #0f7ec7;
        color: #fff;
        transform: translateY(-1px);
    }

    .ai-learning-search-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        margin-top: 0.75rem;
    }

    .ai-learning-search-count,
    .ai-learning-search-position {
        color: #0c4a6e;
        font-size: 0.92rem;
        font-weight: 700;
        white-space: nowrap;
    }

    .ai-learning-search-nav {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
    }

    .ai-learning-search-step {
        width: 2.2rem;
        height: 2.2rem;
        border: 1px solid rgba(15, 126, 199, 0.2);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.92);
        color: #0f4c75;
        font-size: 1rem;
        font-weight: 800;
        cursor: pointer;
        transition: transform 0.15s ease, background 0.15s ease, color 0.15s ease, opacity 0.15s ease;
    }

    .ai-learning-search-step:hover,
    .ai-learning-search-step:focus-visible {
        outline: none;
        background: #0f7ec7;
        color: #fff;
        transform: translateY(-1px);
    }

    .ai-learning-search-step:disabled {
        opacity: 0.45;
        cursor: not-allowed;
        transform: none;
    }

    .ai-learning-match-highlight {
        background: linear-gradient(135deg, #fff1a6, #ffd86b);
        color: #6b4500;
        border-radius: 0.3em;
        padding: 0.04em 0.1em;
        box-shadow: 0 0 0 1px rgba(255, 214, 10, 0.35);
    }

    .ai-learning-entry.is-search-active {
        border-color: rgba(15, 126, 199, 0.24);
        border-left-color: #0891b2;
        box-shadow: 0 0 0 4px rgba(34, 211, 238, 0.18), 0 14px 34px rgba(15, 23, 42, 0.1);
    }

    .ai-learning-entry {
        scroll-margin-top: 7.4rem;
    }

    .ai-learning-jump-groups {
        display: flex;
        flex-direction: column;
        gap: 0.8rem;
    }

    .ai-learning-year-menu {
        border-radius: 14px;
        background: rgba(255, 255, 255, 0.74);
        border: 1px solid rgba(14, 116, 144, 0.12);
        overflow: hidden;
    }

    .ai-learning-year-menu summary {
        cursor: pointer;
        list-style: none;
        padding: 0.9rem 1rem;
        font-weight: 700;
        color: #12324a;
        position: relative;
    }

    .ai-learning-year-menu summary::-webkit-details-marker {
        display: none;
    }

    .ai-learning-year-menu summary::after {
        content: "+";
        position: absolute;
        right: 1rem;
        top: 50%;
        transform: translateY(-50%);
        font-size: 1.1rem;
        color: #0f7ec7;
    }

    .ai-learning-year-menu[open] summary::after {
        content: "−";
    }

    .ai-learning-month-links {
        display: flex;
        flex-wrap: wrap;
        gap: 0.7rem;
        padding: 0 1rem 1rem;
    }

    .ai-learning-month-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 4.2rem;
        padding: 0.5rem 0.8rem;
        border-radius: 999px;
        background: #ffffff;
        color: #0f4c75;
        font-weight: 600;
        text-decoration: none;
        border: 1px solid rgba(15, 126, 199, 0.18);
        transition: transform 0.15s ease, background 0.15s ease, color 0.15s ease;
    }

    .ai-learning-month-link:hover,
    .ai-learning-month-link:focus-visible {
        background: #0f7ec7;
        color: #fff;
        transform: translateY(-1px);
    }

    .ai-learning-entries {
        display: flex;
        flex-direction: column;
        gap: 2.5rem;
    }

    .ai-learning-year-block {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    .ai-learning-year-heading {
        font-size: 1.55rem;
        font-weight: 800;
        color: #0f2740;
    }

    .ai-learning-month-block {
        scroll-margin-top: 6.5rem;
    }

    .ai-learning-month-heading {
        display: inline-flex;
        align-items: center;
        margin-bottom: 1rem;
        padding: 0.38rem 0.75rem;
        border-radius: 999px;
        background: #e0f2fe;
        color: #075985;
        font-size: 0.98rem;
        font-weight: 700;
    }

    .ai-learning-month-entries {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    .ai-learning-entry {
        padding: 1.5rem 1.4rem;
        border: 1px solid rgba(15, 23, 42, 0.1);
        border-left: 5px solid #0f7ec7;
        border-radius: 16px;
        background: var(--post-bg);
        box-shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
    }

    .ai-learning-search-empty {
        display: none;
        padding: 1.15rem 1.2rem;
        border-radius: 16px;
        border: 1px dashed rgba(15, 126, 199, 0.28);
        background: rgba(224, 242, 254, 0.48);
        color: #0c4a6e;
        font-weight: 600;
    }

    .ai-learning-search-empty.is-visible {
        display: block;
    }

    .is-search-hidden {
        display: none !important;
    }

    .ai-learning-entry-date {
        font-size: 1.35rem;
        font-weight: 700;
        letter-spacing: 0.02em;
        color: #0c4a6e;
        margin-bottom: 1rem;
        padding-bottom: 0.85rem;
        border-bottom: 1px dashed rgba(15, 23, 42, 0.14);
    }

    .ai-learning-entry-body > *:first-child {
        margin-top: 0;
    }

    .ai-learning-entry-body > *:last-child {
        margin-bottom: 0;
    }

    .ai-learning-entry-body h2 {
        display: inline-flex;
        align-items: center;
        padding: 0.5rem 0.95rem;
        border-radius: 14px;
        font-size: 1.2rem;
        line-height: 1.4;
        box-shadow: inset 0 0 0 1px rgba(15, 23, 42, 0.06);
    }

    .ai-learning-entry-body h2:nth-of-type(1) {
        background: linear-gradient(135deg, #fff1bf, #ffe08a);
        color: #7a4b00;
    }

    .ai-learning-entry-body h2:nth-of-type(2) {
        background: linear-gradient(135deg, #d9fbe6, #b8f2cf);
        color: #0f5f3c;
    }

    .ai-learning-empty {
        padding: 1.5rem;
        border-radius: 16px;
        background: rgba(148, 163, 184, 0.12);
        color: var(--text);
    }

    @media (min-width: 1100px) {
        .ai-learning-layout {
            display: grid;
            grid-template-columns: minmax(0, 1fr) 260px;
            gap: 2rem;
            align-items: start;
        }

        .ai-learning-main {
            min-width: 0;
        }

        .ai-learning-sidebar {
            margin-top: 4.6rem;
            margin-bottom: 0;
            position: sticky;
            top: 6.4rem;
            align-self: start;
        }

        .ai-learning-jump-nav {
            max-height: calc(100vh - 8rem);
            overflow: auto;
        }

        .ai-learning-month-links {
            flex-direction: column;
            align-items: stretch;
        }

        .ai-learning-month-link {
            width: 100%;
            justify-content: flex-start;
            padding: 0.65rem 0.85rem;
        }
    }

    @media (max-width: 768px) {
        .ai-learning-search-panel,
        .ai-learning-jump-nav {
            padding: 1rem;
        }

        .ai-learning-search-field {
            flex-direction: column;
            align-items: stretch;
        }

        .ai-learning-search-toolbar {
            flex-direction: column;
            align-items: stretch;
        }

        .ai-learning-search-nav {
            justify-content: space-between;
        }

        .ai-learning-search-clear {
            width: 100%;
        }

        .ai-learning-year-menu summary {
            padding: 0.8rem 0.9rem;
        }

        .ai-learning-month-links {
            padding: 0 0.9rem 0.9rem;
            gap: 0.55rem;
        }

        .ai-learning-month-link {
            min-width: 3.6rem;
            padding: 0.45rem 0.7rem;
        }

        .ai-learning-year-heading {
            font-size: 1.35rem;
        }

        .ai-learning-entry {
            padding: 1.2rem 1rem;
        }

        .ai-learning-entry-date {
            font-size: 1.15rem;
        }

        .ai-learning-entry-body h2 {
            font-size: 1.05rem;
            padding: 0.48rem 0.8rem;
        }
    }
</style>
<script>
    window.addEventListener("DOMContentLoaded", () => {
        const searchInput = document.getElementById("ai-learning-search-input");
        const clearButton = document.getElementById("ai-learning-search-clear");
        const toolbar = document.getElementById("ai-learning-search-toolbar");
        const countLabel = document.getElementById("ai-learning-search-count");
        const positionLabel = document.getElementById("ai-learning-search-position");
        const prevButton = document.getElementById("ai-learning-search-prev");
        const nextButton = document.getElementById("ai-learning-search-next");
        const entriesSection = document.querySelector(".ai-learning-entries");

        if (!searchInput || !clearButton || !toolbar || !countLabel || !positionLabel || !prevButton || !nextButton || !entriesSection) {
            return;
        }

        const entryRecords = Array.from(document.querySelectorAll(".ai-learning-entry")).map((entry) => {
            const dateElement = entry.querySelector(".ai-learning-entry-date");
            const bodyElement = entry.querySelector(".ai-learning-entry-body");

            return {
                entry,
                dateElement,
                bodyElement,
                dateHtml: dateElement ? dateElement.innerHTML : "",
                bodyHtml: bodyElement ? bodyElement.innerHTML : "",
                searchText: ""
            };
        });
        const monthBlocks = Array.from(document.querySelectorAll(".ai-learning-month-block"));
        const yearBlocks = Array.from(document.querySelectorAll(".ai-learning-year-block"));
        const yearMenus = Array.from(document.querySelectorAll(".ai-learning-year-menu"));
        const monthLinks = Array.from(document.querySelectorAll(".ai-learning-month-link"));

        if (!entryRecords.length) {
            return;
        }

        const emptyState = document.createElement("div");
        emptyState.className = "ai-learning-search-empty";
        emptyState.setAttribute("aria-live", "polite");
        emptyState.textContent = "沒有找到符合的 AI 學習紀錄。";
        entriesSection.appendChild(emptyState);

        const normalize = (value) => value.toLowerCase().replace(/\s+/g, " ").trim();
        const escapeRegExp = (value) => value.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");

        let matchedRecords = [];
        let activeMatchIndex = -1;
        let lastQuery = "";

        entryRecords.forEach((record) => {
            const dateText = record.dateElement ? record.dateElement.textContent : "";
            const bodyText = record.bodyElement ? record.bodyElement.textContent : "";
            record.searchText = normalize(dateText + " " + bodyText);
        });

        const restoreRecordHtml = (record) => {
            if (record.dateElement) {
                record.dateElement.innerHTML = record.dateHtml;
            }

            if (record.bodyElement) {
                record.bodyElement.innerHTML = record.bodyHtml;
            }
        };

        const highlightInElement = (root, regex) => {
            const textNodes = [];
            const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT, {
                acceptNode(node) {
                    if (!node.nodeValue || !node.nodeValue.trim()) {
                        return NodeFilter.FILTER_REJECT;
                    }

                    const parent = node.parentNode;
                    if (!parent || ["SCRIPT", "STYLE", "MARK"].includes(parent.nodeName)) {
                        return NodeFilter.FILTER_REJECT;
                    }

                    regex.lastIndex = 0;
                    return regex.test(node.nodeValue) ? NodeFilter.FILTER_ACCEPT : NodeFilter.FILTER_REJECT;
                }
            });

            while (walker.nextNode()) {
                textNodes.push(walker.currentNode);
            }

            textNodes.forEach((node) => {
                const fragment = document.createDocumentFragment();
                const text = node.nodeValue;
                let lastIndex = 0;
                let match;

                regex.lastIndex = 0;
                while ((match = regex.exec(text)) !== null) {
                    const matchText = match[0];
                    const start = match.index;

                    if (start > lastIndex) {
                        fragment.appendChild(document.createTextNode(text.slice(lastIndex, start)));
                    }

                    const mark = document.createElement("mark");
                    mark.className = "ai-learning-match-highlight";
                    mark.textContent = matchText;
                    fragment.appendChild(mark);

                    lastIndex = start + matchText.length;
                }

                if (lastIndex < text.length) {
                    fragment.appendChild(document.createTextNode(text.slice(lastIndex)));
                }

                if (node.parentNode) {
                    node.parentNode.replaceChild(fragment, node);
                }
            });
        };

        const highlightRecord = (record, rawQuery) => {
            if (!rawQuery) {
                return;
            }

            const regex = new RegExp(escapeRegExp(rawQuery), "gi");
            if (record.dateElement) {
                highlightInElement(record.dateElement, regex);
            }
            if (record.bodyElement) {
                highlightInElement(record.bodyElement, regex);
            }
        };

        const setToolbarState = (query, matchCount) => {
            if (!query) {
                toolbar.hidden = true;
                return;
            }

            toolbar.hidden = false;
            countLabel.textContent = matchCount + "篇符合";
            positionLabel.textContent = matchCount ? activeMatchIndex + 1 + " / " + matchCount : "0 / 0";
            prevButton.disabled = matchCount <= 1;
            nextButton.disabled = matchCount <= 1;
        };

        const scrollToActiveMatch = () => {
            if (!matchedRecords.length || activeMatchIndex < 0) {
                return;
            }

            matchedRecords.forEach((record, index) => {
                record.entry.classList.toggle("is-search-active", index === activeMatchIndex);
            });

            matchedRecords[activeMatchIndex].entry.scrollIntoView({ behavior: "smooth", block: "start" });
            positionLabel.textContent = activeMatchIndex + 1 + " / " + matchedRecords.length;
        };

        const moveMatch = (direction) => {
            if (matchedRecords.length <= 1) {
                return;
            }

            activeMatchIndex = (activeMatchIndex + direction + matchedRecords.length) % matchedRecords.length;
            scrollToActiveMatch();
        };

        const applyFilter = () => {
            const rawQuery = searchInput.value.trim();
            const query = normalize(rawQuery);
            const queryChanged = rawQuery !== lastQuery;
            let visibleEntries = 0;

            entryRecords.forEach((record) => {
                restoreRecordHtml(record);
                record.entry.classList.remove("is-search-active");

                const matched = !query || record.searchText.includes(query);
                record.entry.classList.toggle("is-search-hidden", !matched);
                if (matched) {
                    visibleEntries += 1;
                }
            });

            monthBlocks.forEach((monthBlock) => {
                const visible = monthBlock.querySelectorAll(".ai-learning-entry:not(.is-search-hidden)").length > 0;
                monthBlock.classList.toggle("is-search-hidden", !visible);
            });

            yearBlocks.forEach((yearBlock, index) => {
                const visible = yearBlock.querySelectorAll(".ai-learning-month-block:not(.is-search-hidden)").length > 0;
                yearBlock.classList.toggle("is-search-hidden", !visible);

                if (yearMenus[index]) {
                    yearMenus[index].classList.toggle("is-search-hidden", !visible);
                    if (query && visible) {
                        yearMenus[index].open = true;
                    }
                }
            });

            monthLinks.forEach((link) => {
                const monthId = link.dataset.targetMonth;
                const monthBlock = monthId ? document.getElementById(monthId) : null;
                const visible = !!monthBlock && !monthBlock.classList.contains("is-search-hidden");
                link.classList.toggle("is-search-hidden", !visible);
            });

            matchedRecords = query
                ? entryRecords.filter((record) => !record.entry.classList.contains("is-search-hidden"))
                : [];

            matchedRecords.forEach((record) => highlightRecord(record, rawQuery));

            if (matchedRecords.length) {
                activeMatchIndex = queryChanged || activeMatchIndex < 0
                    ? 0
                    : Math.min(activeMatchIndex, matchedRecords.length - 1);
                scrollToActiveMatch();
            } else {
                activeMatchIndex = -1;
                positionLabel.textContent = "0 / 0";
            }

            clearButton.hidden = !rawQuery;
            emptyState.classList.toggle("is-visible", !!query && visibleEntries === 0);
            setToolbarState(rawQuery, matchedRecords.length);
            lastQuery = rawQuery;
        };

        searchInput.addEventListener("input", applyFilter);
        searchInput.addEventListener("keydown", (event) => {
            if (event.key === "ArrowDown" && matchedRecords.length) {
                event.preventDefault();
                moveMatch(1);
            }

            if (event.key === "ArrowUp" && matchedRecords.length) {
                event.preventDefault();
                moveMatch(-1);
            }
        });
        clearButton.addEventListener("click", () => {
            searchInput.value = "";
            applyFilter();
            searchInput.focus();
        });
        prevButton.addEventListener("click", () => moveMatch(-1));
        nextButton.addEventListener("click", () => moveMatch(1));
        applyFilter();
    });
</script>
{{ end }}
