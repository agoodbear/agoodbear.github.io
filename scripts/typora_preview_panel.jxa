ObjC.import("AppKit");
ObjC.import("Foundation");
ObjC.import("WebKit");

const env = $.NSProcessInfo.processInfo.environment;
const selectedTextB64 = ObjC.unwrap(env.objectForKey("SELECTED_TEXT_B64")) || "";
const autoSelectId = ObjC.unwrap(env.objectForKey("AUTO_SELECT_ID")) || "";
const autoApply = ObjC.unwrap(env.objectForKey("AUTO_APPLY")) || "";
const choiceFile = ObjC.unwrap(env.objectForKey("CHOICE_FILE")) || "";

function decodeBase64(value) {
  if (!value) return "";
  const data = $.NSData.alloc.initWithBase64EncodedStringOptions($(value), 0);
  if (!data) return "";
  return ObjC.unwrap($.NSString.alloc.initWithDataEncoding(data, $.NSUTF8StringEncoding)) || "";
}

function trimText(value) {
  return value.replace(/\r/g, "\n").trim().replace(/\s+/g, " ");
}

function escapeHtml(value) {
  return value
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;");
}

function escapeShortcode(value) {
  return trimText(value).replace(/\\/g, "\\\\").replace(/"/g, '\\"');
}

const selectedText = decodeBase64(selectedTextB64);
const trimmedSelectedText = trimText(selectedText);
const hasSelectedText = Boolean(trimmedSelectedText);
const imageTemplateLabels = ["第一張圖", "第二張圖", "第三張圖", "第四張圖", "第五張圖", "第六張圖"];

const options = [
  {
    id: "tag-mint",
    menuTitle: "Tag Pill · mint（淺綠標籤）",
    title: "Tag Pill · mint",
    chip: "淺綠標籤",
    desc: "適合放重點提示、章節提示或 ECG 心法類標記。",
    type: "tag",
    tone: "mint",
    requiresSelection: true,
  },
  {
    id: "tag-sky",
    menuTitle: "Tag Pill · sky（淺藍標籤）",
    title: "Tag Pill · sky",
    chip: "淺藍標籤",
    desc: "適合放補充觀念、Pearl、知識點或延伸閱讀。",
    type: "tag",
    tone: "sky",
    requiresSelection: true,
  },
  {
    id: "tag-amber",
    menuTitle: "Tag Pill · amber（淺黃標籤）",
    title: "Tag Pill · amber",
    chip: "淺黃標籤",
    desc: "適合放警示、陷阱、contraindication 或注意事項。",
    type: "tag",
    tone: "amber",
    requiresSelection: true,
  },
  {
    id: "wave-h2",
    menuTitle: "ECG Wave Text · H2（大標題）",
    title: "ECG Wave Text · H2",
    chip: "動態標題",
    desc: "大標題版 ECG 波形標題，語氣俐落，適合案例切段或章節重點。",
    type: "wave",
    level: "2",
    requiresSelection: true,
  },
  {
    id: "wave-h3",
    menuTitle: "ECG Wave Text · H3（中標題）",
    title: "ECG Wave Text · H3",
    chip: "動態小標",
    desc: "中標題版 ECG 波形標題，適合次段落標示，不會太搶畫面。",
    type: "wave",
    level: "3",
    requiresSelection: true,
  },
  {
    id: "notice-flame",
    menuTitle: "學習重點火焰框",
    title: "學習重點火焰框",
    chip: "重點框",
    desc: "將重點清單包成火焰風格學習框，適合文章結尾整理重點。",
    type: "notice",
    style: "flame",
    label: "學習重點",
    requiresSelection: false,
  },
  {
    id: "image-row-2",
    menuTitle: "並排圖片（2 欄）",
    title: "並排圖片（2 欄）",
    chip: "圖片模板",
    desc: "直接在 Typora 游標處插入兩張圖並排的 shortcode，之後自行填入圖片路徑與圖說。",
    type: "imageLayout",
    rows: [2],
    gap: 14,
    requiresSelection: false,
  },
  {
    id: "image-row-3",
    menuTitle: "並排圖片（3 欄）",
    title: "並排圖片（3 欄）",
    chip: "圖片模板",
    desc: "插入三張圖同排的 shortcode 模板，適合同系列比較圖。",
    type: "imageLayout",
    rows: [3],
    gap: 14,
    requiresSelection: false,
  },
  {
    id: "image-row-4",
    menuTitle: "並排圖片（4 欄）",
    title: "並排圖片（4 欄）",
    chip: "圖片模板",
    desc: "插入四張圖同排的 shortcode 模板，適合縮圖總覽。",
    type: "imageLayout",
    rows: [4],
    gap: 14,
    requiresSelection: false,
  },
  {
    id: "image-grid-2-2",
    menuTitle: "圖片拼版（上 2 / 下 2）",
    title: "圖片拼版（上 2 / 下 2）",
    chip: "圖片模板",
    desc: "插入兩排兩張的 shortcode 模板，適合四張圖分組對照。",
